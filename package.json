  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "stream-browserify": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "util": "^0.12.5",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vitest": "^1.4.0"
  }
